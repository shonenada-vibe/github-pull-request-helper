{
  "name": "github-differ",
  "description": "Group a GitHub PR diff into reviewable units with a suggested reading order, on the Files-changed page.",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "postinstall": "wxt prepare",
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "typecheck": "wxt prepare && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/svelte": "^5.2.6",
    "jsdom": "^25.0.1",
    "typescript-eslint": "^8.18.0",
    "@wxt-dev/module-svelte": "^2.0.3",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8",
    "wxt": "^0.20.0"
  },
  "overrides": {
    "vite": "^6.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3"
  }
}
